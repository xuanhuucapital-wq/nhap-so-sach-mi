{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nhap-so-sach-mi",
  "main": "src/worker.js",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
